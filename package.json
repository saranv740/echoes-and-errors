		"lucide-svelte": "^1.0.1",
		"rehype-slug": "^6.0.0",
		"remark-toc": "^9.0.0",
		"shiki": "^3.23.0",
		"shiki-transformer-copy-button": "^0.0.5",
		"tailwindcss": "^4.2.1"
	}
